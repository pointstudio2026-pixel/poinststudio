// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  designer
  admin

  @@map("user_role")
}

enum AdminTier {
  super_admin
  manager
  support

  @@map("admin_tier")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String?   @map("password_hash")
  name            String?   @db.VarChar(120)
  role            UserRole  @default(designer)
  adminTier       AdminTier? @map("admin_tier")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz()
  emailVerificationToken          String?   @unique @map("email_verification_token")
  emailVerificationTokenExpiresAt DateTime? @map("email_verification_token_expires_at") @db.Timestamptz()
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz()
  suspendedAt     DateTime? @map("suspended_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  activityLogs       ActivityLog[]
  refreshTokens      RefreshToken[]
  projects           Project[]
  subscription       Subscription?
  usageLogs          UsageLog[]
  styleFavorites     StyleFavorite[]
  designMemorySettings DesignMemorySettings?
  oauthAccounts      OAuthAccount[]
  userStyleCategories UserStyleCategory[]
  inquiries          Inquiry[]
  trainingExamples   TrainingExample[]
  team               Team?
  teamMemberships    TeamMembership[]

  @@map("users")
}

enum OAuthProviderCode {
  google
  kakao

  @@map("oauth_provider")
}

// 소셜 로그인 연동 (Google/Kakao). 한 User가 여러 Provider를 연결할 수 있도록
// User에 provider 컬럼을 직접 두지 않고 별도 테이블로 분리했다.
model OAuthAccount {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @map("user_id") @db.Uuid
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          OAuthProviderCode
  providerAccountId String            @map("provider_account_id") @db.VarChar(255)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

enum PlanCode {
  free
  pro
  studio

  @@map("plan_code")
}

model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planCode               PlanCode  @default(free) @map("plan_code")
  status                 String    @default("active") @db.VarChar(20)
  currentPeriodStart     DateTime? @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd       DateTime? @map("current_period_end") @db.Timestamptz()
  providerCustomerId     String?   @map("provider_customer_id") @db.VarChar(255)
  providerSubscriptionId String?   @map("provider_subscription_id") @db.VarChar(255)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("subscriptions")
}

model UsageLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?  @map("project_id") @db.Uuid
  project      Project? @relation(fields: [projectId], references: [id])
  eventType    String   @map("event_type") @db.VarChar(50)
  quantity     Int      @default(1)
  costAmount   Decimal? @map("cost_amount") @db.Decimal(12, 6)
  costCurrency String?  @default("USD") @map("cost_currency") @db.VarChar(10)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, eventType, createdAt])
  @@map("usage_logs")
}

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String    @db.VarChar(255)
  status      String    @default("draft") @db.VarChar(30)
  deliverableType String? @map("deliverable_type") @db.VarChar(30)
  currentStep String    @default("deliverable_type") @map("current_step") @db.VarChar(50)
  isFavorite  Boolean   @default(false) @map("is_favorite")
  sharedWithTeam Boolean @default(false) @map("shared_with_team")
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  usageLogs       UsageLog[]
  brandInterviews BrandInterview[]
  brandStrategy   BrandStrategy?
  styleSelections StyleSelection[]
  logoStyleSelections LogoStyleSelection[]
  prompt          Prompt?
  generation      Generation?
  conceptBoard    ConceptBoard?
  mockupProjects  MockupProject[]
  exportJobs      ExportJob[]
  userStyleSelections ProjectUserStyleSelection[]
  colorPaletteSelections ColorPaletteSelection[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("projects")
}

model BrandInterview {
  id                   String    @id @default(uuid()) @db.Uuid
  projectId            String    @map("project_id") @db.Uuid
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status               String    @default("in_progress") @db.VarChar(20)
  currentQuestionIndex Int       @default(0) @map("current_question_index")
  startedAt            DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  completedAt          DateTime? @map("completed_at") @db.Timestamptz()

  answers InterviewAnswer[]

  @@index([projectId])
  @@map("brand_interviews")
}

model InterviewAnswer {
  id           String         @id @default(uuid()) @db.Uuid
  interviewId  String         @map("interview_id") @db.Uuid
  interview    BrandInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  questionKey  String         @map("question_key") @db.VarChar(100)
  questionText String         @map("question_text")
  answer       Json?
  sequence     Int
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([interviewId, questionKey])
  @@map("interview_answers")
}

model BrandStrategy {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions BrandStrategyVersion[]

  @@map("brand_strategies")
}

model BrandStrategyVersion {
  id               String        @id @default(uuid()) @db.Uuid
  brandStrategyId  String        @map("brand_strategy_id") @db.Uuid
  brandStrategy    BrandStrategy @relation(fields: [brandStrategyId], references: [id], onDelete: Cascade)
  versionNumber    Int           @map("version_number")
  data             Json
  candidates       Json          @default("[]")
  selectedIndex    Int?          @map("selected_index")
  reasoningSummary String?       @map("reasoning_summary")
  confidence       String        @db.VarChar(10)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([brandStrategyId, versionNumber])
  @@map("brand_strategy_versions")
}

// 12_PRD_StyleEngine.md Claude Code Instructions: "스타일 데이터는 하드코딩하지
// 말고 관리 가능한 구조로 설계한다" -- seeded reference data (see
// prisma/seedStyles.ts), not an in-code constant. level 1 = 대분류, 2 = 중분류,
// 3 = 소분류 (선택 가능한 leaf style).
model Style {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(160)
  level       Int
  parentId    String?  @map("parent_id") @db.Uuid
  parent      Style?   @relation("StyleHierarchy", fields: [parentId], references: [id])
  children    Style[]  @relation("StyleHierarchy")
  category    String   @db.VarChar(60)
  keywords    String[]
  description String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  primarySelections StyleSelection[] @relation("PrimaryStyle")
  favoritedBy       StyleFavorite[]

  @@index([category, level])
  @@map("styles")
}

model StyleSelection {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  primaryStyleId    String   @map("primary_style_id") @db.Uuid
  primaryStyle      Style    @relation("PrimaryStyle", fields: [primaryStyleId], references: [id])
  secondaryStyleIds String[] @map("secondary_style_ids")
  // 사용자가 명시적으로 배제한 스타일 -- 우선순위 시스템의 하드 제약조건.
  // FK 무결성 없음(secondaryStyleIds와 동일한 배열 관례).
  forbiddenStyleIds String[] @default([]) @map("forbidden_style_ids")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("style_selections")
}

// 프리셋 팔레트 선택이면 presetSlug가 채워지고 swatches는 그 카탈로그 항목을
// 복사한 값, 커스텀 hex 입력이면 presetSlug가 null이고 swatches가 사용자
// 입력값 -- 소비 측(promptBuilder/conceptBoardComposer)은 어느 쪽이든 항상
// swatches만 읽으면 되므로 분기가 필요 없다. StyleSelection과 동일하게
// append-only(재선택 시 새 행 추가, latest-wins).
model ColorPaletteSelection {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  presetSlug String?  @map("preset_slug") @db.VarChar(60)
  swatches   Json
  // 사용자가 명시적으로 금지한 색상(hex) -- 우선순위 시스템의 하드
  // 제약조건. swatches(허용 목록)와 별개의 배제 목록.
  forbiddenColors String[] @default([]) @map("forbidden_colors")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("color_palette_selections")
}

model StyleFavorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  styleId   String   @map("style_id") @db.Uuid
  style     Style    @relation(fields: [styleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([userId, styleId])
  @@map("style_favorites")
}

// 로고 "구조 형태"(워드마크/심볼/일러스트/조합형/프리미엄) 카테고리 -- 위
// Style(무드: 모던/미니멀/럭셔리...)과는 별개 축이라 별도 모델로 분리했다.
// seeded reference data (see prisma/seedLogoStyles.ts), Style Engine과
// 동일한 관리 가능한 구조 원칙을 따른다. "AI 추천" 카드는 DB 행이 아니라
// 이 5개 카테고리를 규칙 기반으로 랭킹한 화면 위젯이다.
model LogoStyleCategory {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique @db.VarChar(60)
  name           String   @db.VarChar(60)
  description    String
  subStyles      String[] @map("sub_styles")
  keywords       String[]
  sampleImageUrl String   @map("sample_image_url")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  selections LogoStyleSelection[]

  @@map("logo_style_categories")
}

model LogoStyleSelection {
  id           String              @id @default(uuid()) @db.Uuid
  projectId    String              @map("project_id") @db.Uuid
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // 1~3개("고급 옵션" 다중 선택) -- Style의 secondaryStyleIds와 동일하게
  // 배열 자체에는 FK 참조 무결성을 걸지 않는다.
  categoryIds  String[]            @map("category_ids")
  primaryCategoryId String         @map("primary_category_id") @db.Uuid
  primaryCategory   LogoStyleCategory @relation(fields: [primaryCategoryId], references: [id])
  // 사용자가 명시적으로 배제한 로고 스타일 카테고리 -- 우선순위 시스템의
  // 하드 제약조건. categoryIds와 동일하게 FK 무결성 없음.
  forbiddenCategoryIds String[]    @default([]) @map("forbidden_category_ids")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("logo_style_selections")
}

// "내 스타일" -- 사용자가 직접 올린 참고 이미지 카테고리. 계정 전체에서
// 재사용 가능(StyleFavorite/DesignMemory와 동일하게 userId 단위, projectId
// 없음). description은 업로드 시 1회 비전 분석 AI 호출로 뽑은 시각적 스타일
// 텍스트 -- 원본 이미지는 프롬프트에 절대 직접 섞지 않고 이 텍스트만 쓴다.
model UserStyleCategory {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  references        UserStyleReference[]
  projectSelections ProjectUserStyleSelection[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("user_style_categories")
}

model UserStyleReference {
  id          String            @id @default(uuid()) @db.Uuid
  categoryId  String            @map("category_id") @db.Uuid
  category    UserStyleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  storageKey  String            @map("storage_key") @db.VarChar(255)
  contentType String            @map("content_type") @db.VarChar(50)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  @@map("user_style_references")
}

// StyleSelection/LogoStyleSelection과 동일한 append-only 이력 패턴 --
// 프로젝트당 0개(내 스타일 미사용)거나 여러 개(재선택 이력), 최신 것이 유효.
// 어떤 워크스페이스 단계도 게이팅하지 않는 순수 부가 선택이다.
model ProjectUserStyleSelection {
  id                  String            @id @default(uuid()) @db.Uuid
  projectId           String            @map("project_id") @db.Uuid
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userStyleCategoryId String            @map("user_style_category_id") @db.Uuid
  userStyleCategory   UserStyleCategory @relation(fields: [userStyleCategoryId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("project_user_style_selections")
}

model Prompt {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions PromptVersion[]

  @@map("prompts")
}

model PromptVersion {
  id            String   @id @default(uuid()) @db.Uuid
  promptId      String   @map("prompt_id") @db.Uuid
  prompt        Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  versionNumber Int      @map("version_number")
  provider      String   @db.VarChar(30)
  systemPrompt  String   @map("system_prompt")
  userPrompt    String   @map("user_prompt")
  hash          String   @db.VarChar(64)
  payload       Json
  flaggedTerms  String[] @map("flagged_terms")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  decisionRecord PromptDecisionRecord?

  @@unique([promptId, versionNumber])
  @@index([hash])
  @@map("prompt_versions")
}

model Generation {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions GenerationVersion[]
  edits    EditHistory[]

  @@map("generations")
}

model GenerationVersion {
  id              String    @id @default(uuid()) @db.Uuid
  generationId    String    @map("generation_id") @db.Uuid
  generation      Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  versionNumber   Int       @map("version_number")
  promptVersionId String    @map("prompt_version_id") @db.Uuid
  status          String    @default("pending") @db.VarChar(20)
  provider        String?   @db.VarChar(30)
  providerPreference String? @map("provider_preference") @db.VarChar(30)
  images          Json      @default("[]")
  errorMessage    String?   @map("error_message")
  costAmount      Decimal?  @map("cost_amount") @db.Decimal(12, 6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()

  evaluation GenerationEvaluation?
  feedback   GenerationFeedback?

  @@unique([generationId, versionNumber])
  @@map("generation_versions")
}

// "원본 이미지 보존": edits never mutate a GenerationVersion's images --
// each edit appends a brand-new GenerationVersion (reusing the exact same
// versioning machinery as a fresh generation) and this table only records
// the edit-specific lineage: which source image, which preset, which
// resulting version.
model EditHistory {
  id               String    @id @default(uuid()) @db.Uuid
  generationId     String    @map("generation_id") @db.Uuid
  generation       Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  sourceVersionId  String    @map("source_version_id") @db.Uuid
  sourceImageIndex Int       @map("source_image_index")
  presetKey        String?   @map("preset_key") @db.VarChar(40)
  customInstruction String?  @map("custom_instruction")
  resultVersionId  String    @map("result_version_id") @db.Uuid
  status           String    @default("pending") @db.VarChar(20)
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt      DateTime? @map("completed_at") @db.Timestamptz()

  @@index([generationId, createdAt(sort: Desc)])
  @@map("edit_history")
}

model ConceptBoard {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions ConceptBoardVersion[]

  @@map("concept_boards")
}

model ConceptBoardVersion {
  id             String       @id @default(uuid()) @db.Uuid
  conceptBoardId String       @map("concept_board_id") @db.Uuid
  conceptBoard   ConceptBoard @relation(fields: [conceptBoardId], references: [id], onDelete: Cascade)
  versionNumber  Int          @map("version_number")
  data           Json
  source         String       @default("ai") @db.VarChar(30)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([conceptBoardId, versionNumber])
  @@map("concept_board_versions")
}

// "템플릿은 확장 가능한 구조로 설계" -- seeded reference data (see
// prisma/seedMockupTemplates.ts), not an in-code constant, mirroring the
// Style Engine's taxonomy approach. Placement is a simple percentage rect
// so the render step doesn't need real image dimensions.
model MockupTemplate {
  id                 String   @id @default(uuid()) @db.Uuid
  category           String   @db.VarChar(30)
  name               String   @db.VarChar(120)
  slug               String   @unique @db.VarChar(160)
  description        String
  backgroundUrl      String   @map("background_url")
  placementXPct      Float    @map("placement_x_pct")
  placementYPct      Float    @map("placement_y_pct")
  placementWidthPct  Float    @map("placement_width_pct")
  placementHeightPct Float    @map("placement_height_pct")
  // 완성된 결과물(포스터/브로슈어 등)을 로고 마크가 아니라 통째로 크게
  // 합성할 때 쓰는 두 번째 배치 영역 -- 매핑된 deliverableType이 없으면
  // null이고, 그 경우 로직은 위 placementXPct 등(로고 마크용)으로 폴백한다.
  fullDesignPlacementXPct      Float?   @map("full_design_placement_x_pct")
  fullDesignPlacementYPct      Float?   @map("full_design_placement_y_pct")
  fullDesignPlacementWidthPct  Float?   @map("full_design_placement_width_pct")
  fullDesignPlacementHeightPct Float?   @map("full_design_placement_height_pct")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  mockups MockupProject[]

  @@index([category])
  @@map("mockup_templates")
}

// Each render is its own row (not a single versioned document like Brand
// Brief/Strategy) -- "다중 Mockup 생성" means many independent mockups per
// project, and "재생성" just calls the same render endpoint again with the
// same source+template, appending a new row rather than replacing one.
model MockupProject {
  id                  String    @id @default(uuid()) @db.Uuid
  projectId           String    @map("project_id") @db.Uuid
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generationVersionId String    @map("generation_version_id") @db.Uuid
  sourceImageIndex    Int       @default(0) @map("source_image_index")
  templateId          String    @map("template_id") @db.Uuid
  template            MockupTemplate @relation(fields: [templateId], references: [id])
  status              String    @default("pending") @db.VarChar(20)
  resultImageUrl      String?   @map("result_image_url")
  thumbnailUrl        String?   @map("thumbnail_url")
  provider            String?   @db.VarChar(30)
  isFavorite          Boolean   @default(false) @map("is_favorite")
  errorMessage        String?   @map("error_message")
  costAmount          Decimal?  @map("cost_amount") @db.Decimal(12, 6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt         DateTime? @map("completed_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("mockup_projects")
}

// Not in Task-019's own DB list (only activity_logs/usage_logs), but a
// structured, queryable Export History needs its own table -- an
// activity_log row alone can't hold status/fileKey/retry state.
model ExportJob {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source           String    @db.VarChar(20)
  format           String    @db.VarChar(10)
  sourceRefId      String?   @map("source_ref_id") @db.Uuid
  sections         String[]  @default([])
  includeBrandInfo Boolean   @default(true) @map("include_brand_info")
  status           String    @default("pending") @db.VarChar(20)
  fileKey          String?   @map("file_key")
  fileSizeBytes    Int?      @map("file_size_bytes")
  watermarked      Boolean   @default(false)
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt      DateTime? @map("completed_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("export_jobs")
}

// "메모리 초기화" never deletes the underlying signal rows (StyleSelection/
// EditHistory/etc. are other features' own project history) -- resetAt is
// a cutoff timestamp: recommendations only look at signals created after
// it. "비활성화" is enforced at read time (GetDesignMemoryUseCase returns
// an empty profile), not by blocking writes in four already-shipped
// modules.
model DesignMemorySettings {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled   Boolean   @default(true)
  resetAt   DateTime? @map("reset_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("design_memory_settings")
}

model SystemAnnouncement {
  id            String    @id @default(uuid()) @db.Uuid
  message       String
  active        Boolean   @default(true)
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamptz()

  @@index([active, createdAt(sort: Desc)])
  @@map("system_announcements")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique @map("token_hash")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz()
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId])
  @@map("refresh_tokens")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  projectId String?  @map("project_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(80)
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, createdAt])
  @@map("activity_logs")
}

model Inquiry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String   @db.VarChar(200)
  message   String   @db.Text
  isPublic  Boolean  @default(false) @map("is_public")
  locale    String   @default("ko") @db.VarChar(5)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, createdAt(sort: Desc)])
  @@index([isPublic, createdAt(sort: Desc)])
  @@index([locale, isPublic, createdAt(sort: Desc)])
  @@map("inquiries")
}

// Studio 전용: 소유자당 팀 최대 1개, 가입 시 발급된 6자리 코드로 다른
// 사용자가 참여한다. 참여 자체엔 승인 절차가 없다(JoinTeamUseCase).
model Team {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @unique @map("owner_id") @db.Uuid
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  code        String   @unique @db.VarChar(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  memberships TeamMembership[]

  @@map("teams")
}

model TeamMembership {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([teamId, userId])
  @@map("team_memberships")
}

// 관리자가 직접 입력하는 (프롬프트, 생성 이미지) 참고 자료 -- 향후 실제
// 프로젝트의 프롬프트 생성(BuildPromptUseCase)에서 deliverableType +
// 키워드 겹침으로 매칭되면 그 프롬프트 원문 일부가 참고 문구로 포함된다.
// 의도적으로 Vision AI 분석을 하지 않는다(비용 발생 금지) -- prompt 필드
// 자체가 이미 텍스트 학습 데이터이므로 결정론적 키워드 매칭만으로 충분하다.
model TrainingExample {
  id               String   @id @default(uuid()) @db.Uuid
  prompt           String   @db.Text
  deliverableType  String   @map("deliverable_type") @db.VarChar(30)
  imageStorageKey  String   @map("image_storage_key")
  imageContentType String   @map("image_content_type") @db.VarChar(50)
  createdByUserId  String   @map("created_by_user_id") @db.Uuid
  createdBy        User     @relation(fields: [createdByUserId], references: [id])
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // 어떤 생성 파이프라인의 참고 자료인지 -- "이미지생성"(BuildPromptUseCase,
  // 실제 브랜드 이미지 생성)과 "목업"(ProcessMockupJobUseCase, 목업 합성)은
  // 완전히 다른 프롬프트 파이프라인이라 데이터를 절대 섞지 않는다. 자유
  // 문자열이라 관리자가 나중에 새 카테고리를 더 추가할 수 있다(닫힌 enum
  // 아님). 기존 행은 전부 "이미지생성"으로 마이그레이션됨.
  category String @default("이미지생성") @db.VarChar(30)
  // 업종별로도 매칭할 수 있도록(선택 사항) -- interviewQuestions.ts의
  // INDUSTRY_OPTIONS와 동일한 값을 쓴다. 기존 행은 null(업종 미지정).
  industry String? @db.VarChar(30)

  // 텍스트 레벨 평가(안전성 게이트 + 독창성) -- Vision AI 없음, AI 비용 0.
  // 브랜드적합성/실용성/가독성은 프로젝트 컨텍스트가 없어 평가 불가하므로
  // evaluationBreakdown 안에 null + 사유로 명시(거짓 평균 금지).
  evaluationScore     Float?    @map("evaluation_score")
  evaluationBreakdown Json?     @map("evaluation_breakdown")
  evaluatedAt         DateTime? @map("evaluated_at") @db.Timestamptz()
  // 이 자료가 어디서 왔는지 -- 관리자 직접 입력 / 실제 사용자 생성물 승격 /
  // (나중에) 리서치한 실제 브랜드 사례.
  source                    String  @default("ADMIN") @db.VarChar(20)
  sourceGenerationVersionId String? @map("source_generation_version_id") @db.Uuid

  @@index([deliverableType])
  @@index([evaluationScore])
  @@index([category])
  @@map("training_examples")
}

// 프롬프트 조립 시점의 우선순위 판단 기록 -- PromptVersion 1:1, 관리자
// 가시성 전용(실제 조립 로직은 promptBuilder.ts가 그대로 담당한다).
model PromptDecisionRecord {
  id                String        @id @default(uuid()) @db.Uuid
  promptVersionId   String        @unique @map("prompt_version_id") @db.Uuid
  promptVersion     PromptVersion @relation(fields: [promptVersionId], references: [id], onDelete: Cascade)
  hardConstraints   Json          @map("hard_constraints")
  softPreferences   Json          @map("soft_preferences")
  dbCandidatesFound Json          @map("db_candidates_found")
  dbCandidatesUsed  Json          @map("db_candidates_used")
  conflicts         Json          @default("[]")
  complianceCheck   Json          @map("compliance_check")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  @@map("prompt_decision_records")
}

// 생성 결과 1건에 대한 텍스트 레벨(프롬프트 준수) 평가 -- 이미지 픽셀 자체는
// 검증하지 않는다(status로 명시). Vision AI 없음, AI 비용 0.
model GenerationEvaluation {
  id                   String            @id @default(uuid()) @db.Uuid
  generationVersionId  String            @unique @map("generation_version_id") @db.Uuid
  generationVersion    GenerationVersion @relation(fields: [generationVersionId], references: [id], onDelete: Cascade)
  status               String            @default("PROMPT_LEVEL_ONLY") @db.VarChar(30)
  hardConstraintPassed Boolean           @map("hard_constraint_passed")
  issues               Json              @default("[]")
  usageScore           Float?            @map("usage_score")
  promotedToReference  Boolean           @default(false) @map("promoted_to_reference")
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  @@map("generation_evaluations")
}

// 생성 결과에 대한 사용자 본인의 평가 -- 선택형 태그(타이핑 불필요) +
// 자유 텍스트(선택), 완전히 건너뛰기 가능(행이 없으면 그냥 평가 안 한
// 것). AI 호출 없음, 비용 0.
model GenerationFeedback {
  id                  String            @id @default(uuid()) @db.Uuid
  generationVersionId String            @unique @map("generation_version_id") @db.Uuid
  generationVersion   GenerationVersion @relation(fields: [generationVersionId], references: [id], onDelete: Cascade)
  likedTags           String[]          @default([]) @map("liked_tags")
  dislikedTags        String[]          @default([]) @map("disliked_tags")
  freeText            String?           @map("free_text") @db.Text
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  @@map("generation_feedback")
}
