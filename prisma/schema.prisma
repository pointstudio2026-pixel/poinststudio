// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  designer
  admin

  @@map("user_role")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String?   @map("password_hash")
  name            String?   @db.VarChar(120)
  role            UserRole  @default(designer)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  activityLogs       ActivityLog[]
  refreshTokens      RefreshToken[]
  projects           Project[]
  subscription       Subscription?
  usageLogs          UsageLog[]
  brandBriefVersions BrandBriefVersion[]
  styleFavorites     StyleFavorite[]
  designMemorySettings DesignMemorySettings?

  @@map("users")
}

enum PlanCode {
  free
  pro
  studio

  @@map("plan_code")
}

model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planCode               PlanCode  @default(free) @map("plan_code")
  status                 String    @default("active") @db.VarChar(20)
  currentPeriodStart     DateTime? @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd       DateTime? @map("current_period_end") @db.Timestamptz()
  providerCustomerId     String?   @map("provider_customer_id") @db.VarChar(255)
  providerSubscriptionId String?   @map("provider_subscription_id") @db.VarChar(255)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("subscriptions")
}

model UsageLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?  @map("project_id") @db.Uuid
  project      Project? @relation(fields: [projectId], references: [id])
  eventType    String   @map("event_type") @db.VarChar(50)
  quantity     Int      @default(1)
  costAmount   Decimal? @map("cost_amount") @db.Decimal(12, 6)
  costCurrency String?  @default("USD") @map("cost_currency") @db.VarChar(10)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, eventType, createdAt])
  @@map("usage_logs")
}

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String    @db.VarChar(255)
  status      String    @default("draft") @db.VarChar(30)
  currentStep String    @default("brand_interview") @map("current_step") @db.VarChar(50)
  isFavorite  Boolean   @default(false) @map("is_favorite")
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  usageLogs       UsageLog[]
  brandInterviews BrandInterview[]
  brandBrief      BrandBrief?
  brandStrategy   BrandStrategy?
  styleSelections StyleSelection[]
  prompt          Prompt?
  generation      Generation?
  conceptBoard    ConceptBoard?
  mockupProjects  MockupProject[]
  exportJobs      ExportJob[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("projects")
}

model BrandInterview {
  id                   String    @id @default(uuid()) @db.Uuid
  projectId            String    @map("project_id") @db.Uuid
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status               String    @default("in_progress") @db.VarChar(20)
  currentQuestionIndex Int       @default(0) @map("current_question_index")
  startedAt            DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  completedAt          DateTime? @map("completed_at") @db.Timestamptz()

  answers InterviewAnswer[]

  @@index([projectId])
  @@map("brand_interviews")
}

model InterviewAnswer {
  id           String         @id @default(uuid()) @db.Uuid
  interviewId  String         @map("interview_id") @db.Uuid
  interview    BrandInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  questionKey  String         @map("question_key") @db.VarChar(100)
  questionText String         @map("question_text")
  answer       Json?
  sequence     Int
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([interviewId, questionKey])
  @@map("interview_answers")
}

model BrandBrief {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions BrandBriefVersion[]

  @@map("brand_briefs")
}

model BrandBriefVersion {
  id            String     @id @default(uuid()) @db.Uuid
  brandBriefId  String     @map("brand_brief_id") @db.Uuid
  brandBrief    BrandBrief @relation(fields: [brandBriefId], references: [id], onDelete: Cascade)
  versionNumber Int        @map("version_number")
  data          Json
  source        String     @default("ai") @db.VarChar(30)
  createdBy     String?    @map("created_by") @db.Uuid
  createdByUser User?      @relation(fields: [createdBy], references: [id])
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([brandBriefId, versionNumber])
  @@map("brand_brief_versions")
}

model BrandStrategy {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions BrandStrategyVersion[]

  @@map("brand_strategies")
}

model BrandStrategyVersion {
  id               String        @id @default(uuid()) @db.Uuid
  brandStrategyId  String        @map("brand_strategy_id") @db.Uuid
  brandStrategy    BrandStrategy @relation(fields: [brandStrategyId], references: [id], onDelete: Cascade)
  versionNumber    Int           @map("version_number")
  data             Json
  reasoningSummary String?       @map("reasoning_summary")
  confidence       String        @db.VarChar(10)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([brandStrategyId, versionNumber])
  @@map("brand_strategy_versions")
}

// 12_PRD_StyleEngine.md Claude Code Instructions: "스타일 데이터는 하드코딩하지
// 말고 관리 가능한 구조로 설계한다" -- seeded reference data (see
// prisma/seedStyles.ts), not an in-code constant. level 1 = 대분류, 2 = 중분류,
// 3 = 소분류 (선택 가능한 leaf style).
model Style {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(160)
  level       Int
  parentId    String?  @map("parent_id") @db.Uuid
  parent      Style?   @relation("StyleHierarchy", fields: [parentId], references: [id])
  children    Style[]  @relation("StyleHierarchy")
  category    String   @db.VarChar(60)
  keywords    String[]
  description String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  primarySelections StyleSelection[] @relation("PrimaryStyle")
  favoritedBy       StyleFavorite[]

  @@index([category, level])
  @@map("styles")
}

model StyleSelection {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  primaryStyleId    String   @map("primary_style_id") @db.Uuid
  primaryStyle      Style    @relation("PrimaryStyle", fields: [primaryStyleId], references: [id])
  secondaryStyleIds String[] @map("secondary_style_ids")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("style_selections")
}

model StyleFavorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  styleId   String   @map("style_id") @db.Uuid
  style     Style    @relation(fields: [styleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([userId, styleId])
  @@map("style_favorites")
}

model Prompt {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions PromptVersion[]

  @@map("prompts")
}

model PromptVersion {
  id            String   @id @default(uuid()) @db.Uuid
  promptId      String   @map("prompt_id") @db.Uuid
  prompt        Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  versionNumber Int      @map("version_number")
  provider      String   @db.VarChar(30)
  systemPrompt  String   @map("system_prompt")
  userPrompt    String   @map("user_prompt")
  hash          String   @db.VarChar(64)
  payload       Json
  flaggedTerms  String[] @map("flagged_terms")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([promptId, versionNumber])
  @@index([hash])
  @@map("prompt_versions")
}

model Generation {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions GenerationVersion[]
  edits    EditHistory[]

  @@map("generations")
}

model GenerationVersion {
  id              String    @id @default(uuid()) @db.Uuid
  generationId    String    @map("generation_id") @db.Uuid
  generation      Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  versionNumber   Int       @map("version_number")
  promptVersionId String    @map("prompt_version_id") @db.Uuid
  status          String    @default("pending") @db.VarChar(20)
  provider        String?   @db.VarChar(30)
  images          Json      @default("[]")
  errorMessage    String?   @map("error_message")
  costAmount      Decimal?  @map("cost_amount") @db.Decimal(12, 6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()

  @@unique([generationId, versionNumber])
  @@map("generation_versions")
}

// "원본 이미지 보존": edits never mutate a GenerationVersion's images --
// each edit appends a brand-new GenerationVersion (reusing the exact same
// versioning machinery as a fresh generation) and this table only records
// the edit-specific lineage: which source image, which preset, which
// resulting version.
model EditHistory {
  id               String    @id @default(uuid()) @db.Uuid
  generationId     String    @map("generation_id") @db.Uuid
  generation       Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  sourceVersionId  String    @map("source_version_id") @db.Uuid
  sourceImageIndex Int       @map("source_image_index")
  presetKey        String    @map("preset_key") @db.VarChar(40)
  resultVersionId  String    @map("result_version_id") @db.Uuid
  status           String    @default("pending") @db.VarChar(20)
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt      DateTime? @map("completed_at") @db.Timestamptz()

  @@index([generationId, createdAt(sort: Desc)])
  @@map("edit_history")
}

model ConceptBoard {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @unique @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  versions ConceptBoardVersion[]

  @@map("concept_boards")
}

model ConceptBoardVersion {
  id             String       @id @default(uuid()) @db.Uuid
  conceptBoardId String       @map("concept_board_id") @db.Uuid
  conceptBoard   ConceptBoard @relation(fields: [conceptBoardId], references: [id], onDelete: Cascade)
  versionNumber  Int          @map("version_number")
  data           Json
  source         String       @default("ai") @db.VarChar(30)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([conceptBoardId, versionNumber])
  @@map("concept_board_versions")
}

// "템플릿은 확장 가능한 구조로 설계" -- seeded reference data (see
// prisma/seedMockupTemplates.ts), not an in-code constant, mirroring the
// Style Engine's taxonomy approach. Placement is a simple percentage rect
// so the render step doesn't need real image dimensions.
model MockupTemplate {
  id                 String   @id @default(uuid()) @db.Uuid
  category           String   @db.VarChar(30)
  name               String   @db.VarChar(120)
  slug               String   @unique @db.VarChar(160)
  description        String
  backgroundUrl      String   @map("background_url")
  placementXPct      Float    @map("placement_x_pct")
  placementYPct      Float    @map("placement_y_pct")
  placementWidthPct  Float    @map("placement_width_pct")
  placementHeightPct Float    @map("placement_height_pct")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  mockups MockupProject[]

  @@index([category])
  @@map("mockup_templates")
}

// Each render is its own row (not a single versioned document like Brand
// Brief/Strategy) -- "다중 Mockup 생성" means many independent mockups per
// project, and "재생성" just calls the same render endpoint again with the
// same source+template, appending a new row rather than replacing one.
model MockupProject {
  id                  String    @id @default(uuid()) @db.Uuid
  projectId           String    @map("project_id") @db.Uuid
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generationVersionId String    @map("generation_version_id") @db.Uuid
  sourceImageIndex    Int       @default(0) @map("source_image_index")
  templateId          String    @map("template_id") @db.Uuid
  template            MockupTemplate @relation(fields: [templateId], references: [id])
  status              String    @default("pending") @db.VarChar(20)
  resultImageUrl      String?   @map("result_image_url")
  thumbnailUrl        String?   @map("thumbnail_url")
  provider            String?   @db.VarChar(30)
  isFavorite          Boolean   @default(false) @map("is_favorite")
  errorMessage        String?   @map("error_message")
  costAmount          Decimal?  @map("cost_amount") @db.Decimal(12, 6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt         DateTime? @map("completed_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("mockup_projects")
}

// Not in Task-019's own DB list (only activity_logs/usage_logs), but a
// structured, queryable Export History needs its own table -- an
// activity_log row alone can't hold status/fileKey/retry state.
model ExportJob {
  id               String    @id @default(uuid()) @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source           String    @db.VarChar(20)
  format           String    @db.VarChar(10)
  sourceRefId      String?   @map("source_ref_id") @db.Uuid
  sections         String[]  @default([])
  includeBrandInfo Boolean   @default(true) @map("include_brand_info")
  status           String    @default("pending") @db.VarChar(20)
  fileKey          String?   @map("file_key")
  fileSizeBytes    Int?      @map("file_size_bytes")
  watermarked      Boolean   @default(false)
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt      DateTime? @map("completed_at") @db.Timestamptz()

  @@index([projectId, createdAt(sort: Desc)])
  @@map("export_jobs")
}

// "메모리 초기화" never deletes the underlying signal rows (StyleSelection/
// EditHistory/etc. are other features' own project history) -- resetAt is
// a cutoff timestamp: recommendations only look at signals created after
// it. "비활성화" is enforced at read time (GetDesignMemoryUseCase returns
// an empty profile), not by blocking writes in four already-shipped
// modules.
model DesignMemorySettings {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled   Boolean   @default(true)
  resetAt   DateTime? @map("reset_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("design_memory_settings")
}

model SystemAnnouncement {
  id            String    @id @default(uuid()) @db.Uuid
  message       String
  active        Boolean   @default(true)
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamptz()

  @@index([active, createdAt(sort: Desc)])
  @@map("system_announcements")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique @map("token_hash")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz()
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId])
  @@map("refresh_tokens")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  projectId String?  @map("project_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(80)
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, createdAt])
  @@map("activity_logs")
}
