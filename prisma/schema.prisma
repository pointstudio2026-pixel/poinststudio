// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  designer
  admin

  @@map("user_role")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String?   @map("password_hash")
  name            String?   @db.VarChar(120)
  role            UserRole  @default(designer)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]
  projects      Project[]
  subscription  Subscription?
  usageLogs     UsageLog[]

  @@map("users")
}

enum PlanCode {
  free
  pro
  studio

  @@map("plan_code")
}

model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planCode               PlanCode  @default(free) @map("plan_code")
  status                 String    @default("active") @db.VarChar(20)
  currentPeriodStart     DateTime? @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd       DateTime? @map("current_period_end") @db.Timestamptz()
  providerCustomerId     String?   @map("provider_customer_id") @db.VarChar(255)
  providerSubscriptionId String?   @map("provider_subscription_id") @db.VarChar(255)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("subscriptions")
}

model UsageLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?  @map("project_id") @db.Uuid
  project      Project? @relation(fields: [projectId], references: [id])
  eventType    String   @map("event_type") @db.VarChar(50)
  quantity     Int      @default(1)
  costAmount   Decimal? @map("cost_amount") @db.Decimal(12, 6)
  costCurrency String?  @default("USD") @map("cost_currency") @db.VarChar(10)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, eventType, createdAt])
  @@map("usage_logs")
}

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String    @db.VarChar(255)
  status      String    @default("draft") @db.VarChar(30)
  currentStep String    @default("brand_interview") @map("current_step") @db.VarChar(50)
  isFavorite  Boolean   @default(false) @map("is_favorite")
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  usageLogs       UsageLog[]
  brandInterviews BrandInterview[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("projects")
}

model BrandInterview {
  id                   String    @id @default(uuid()) @db.Uuid
  projectId            String    @map("project_id") @db.Uuid
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status               String    @default("in_progress") @db.VarChar(20)
  currentQuestionIndex Int       @default(0) @map("current_question_index")
  startedAt            DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  completedAt          DateTime? @map("completed_at") @db.Timestamptz()

  answers InterviewAnswer[]

  @@index([projectId])
  @@map("brand_interviews")
}

model InterviewAnswer {
  id           String         @id @default(uuid()) @db.Uuid
  interviewId  String         @map("interview_id") @db.Uuid
  interview    BrandInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  questionKey  String         @map("question_key") @db.VarChar(100)
  questionText String         @map("question_text")
  answer       Json?
  sequence     Int
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([interviewId, questionKey])
  @@map("interview_answers")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique @map("token_hash")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz()
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId])
  @@map("refresh_tokens")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  projectId String?  @map("project_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(80)
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId, createdAt])
  @@map("activity_logs")
}
