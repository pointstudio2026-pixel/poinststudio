# Copy to .env and fill in real values. Never commit .env.
NODE_ENV=development

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
REDIS_URL="redis://HOST:6379"

JWT_ACCESS_SECRET="change-me"

# Optional: without all four of these, exported files (PDF/PNG/JPG) and User
# Styles reference images are written to local disk (src/shared/storage/
# LocalFileStorage.ts) -- fine for local dev, but breaks on deployments where
# the app and worker run in separate containers that don't share a disk
# (e.g. Railway). Fill these in with a real S3-compatible bucket (Cloudflare
# R2 recommended -- generous free tier, no egress fees) for production.
STORAGE_ENDPOINT=""
STORAGE_REGION="auto"
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# Optional: without any of these three, AI features (Aster Brain, interview
# follow-up questions, image generation) fall back to a template-based Mock
# provider so the app stays fully functional without a key. All three text
# providers can be configured at once -- OpenAI wins by default when
# multiple are set; force a specific one with TEXT_COMPLETION_PROVIDER
# ("openai"|"gemini"|"claude"). Image generation only supports OpenAI/Gemini
# (Claude has no image API) -- force with IMAGE_GENERATION_PROVIDER
# ("openai"|"gemini").
OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
TEXT_COMPLETION_PROVIDER=""
IMAGE_GENERATION_PROVIDER=""

# Optional: without RESEND_API_KEY, verification emails fall back to a
# console-log Mock provider (src/shared/email/MockEmailProvider.ts) so
# registration/email-verification still works end-to-end during dev -- the
# verification link just shows up in the server log instead of an inbox.
# Resend's free tier covers a few thousand emails/month, more than enough
# for early usage. EMAIL_FROM_ADDRESS is optional (falls back to a
# resend.dev sandbox sender). APP_BASE_URL is used to build the absolute
# verification link (the use case has no HTTP request to read the origin from).
RESEND_API_KEY=""
EMAIL_FROM_ADDRESS=""
APP_BASE_URL="http://localhost:3100"

# Optional: Google/Kakao social login. Leave empty to keep the "Google로
# 계속하기"/"Kakao로 계속하기" buttons rendered but inactive -- clicking
# them redirects back to /login with a "not connected yet" message instead
# of breaking. Redirect URIs to register with each provider:
#   Google:  {origin}/api/auth/oauth/google/callback
#   Kakao:   {origin}/api/auth/oauth/kakao/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
# Kakao's Client Secret is only required if "Client Secret 사용" is turned
# on in the Kakao Developers console for this app.
KAKAO_CLIENT_SECRET=""
