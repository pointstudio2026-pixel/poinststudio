# Copy to .env and fill in real values. Never commit .env.
NODE_ENV=development

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
REDIS_URL="redis://HOST:6379"

JWT_ACCESS_SECRET="change-me"

STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="aster-dev"
STORAGE_ACCESS_KEY_ID="change-me"
STORAGE_SECRET_ACCESS_KEY="change-me"

# Optional: without this, Task-008's follow-up questions (and later AI
# features) fall back to a template-based Mock provider so the app stays
# fully functional without a key.
OPENAI_API_KEY=""
